@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/LibScreenshotsTargets.cmake")
include(CMakeFindDependencyMacro)

# WLRoots backend
if(@LIBSCREENSHOTS_BACKEND_WLROOTS@)
find_dependency(PkgConfig)
pkg_check_modules(WAYLAND_CLIENT REQUIRED wayland-client)
pkg_check_modules(WAYLAND_CURSOR REQUIRED wayland-cursor)
pkg_check_modules(WAYLAND_EGL REQUIRED wayland-egl)
endif()

# X11 backend
if(@LIBSCREENSHOTS_BACKEND_X11@)
find_dependency(X11)
endif()

# Windows backend
if(@LIBSCREENSHOTS_BACKEND_WINDOWS@)
# eventueel Windows deps
endif()
